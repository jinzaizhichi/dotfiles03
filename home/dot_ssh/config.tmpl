HashKnownHosts no

{{- if eq .chezmoi.os "darwin" }}

Host *
  AddKeysToAgent yes
  UseKeychain yes
{{- end }}

Host fedora
  HostName fedora

Host github.com
  User git

Host macbook-air-m3
  User twp

Host pi-hole
  SetEnv TERM=xterm-256color # https://github.com/pi-hole/pi-hole/issues/6048

Host proxmox
  HostName proxmox
  User root

Host ubuntu
  HostName ubuntu

Host windows
  HostName windows
  User twpay
